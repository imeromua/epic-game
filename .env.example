# ==========================================
# EpicTeam Drive — змінні середовища
# Скопіюй в .env і заповни своїми значеннями
# ==========================================

# --- Telegram ---
BOT_TOKEN=your_bot_token_here
MINIAPP_URL=https://your-domain.com
GROUP_CHAT_ID=-100xxxxxxxxxx

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=epicteam
POSTGRES_USER=epicteam_user
POSTGRES_PASSWORD=your_strong_password
DATABASE_URL=postgresql+asyncpg://epicteam_user:your_strong_password@localhost:5432/epicteam

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET=your_very_long_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
CORS_ORIGINS=["https://your-domain.com"]

# --- Scheduler ---
TIMEZONE=Europe/Kyiv

# --- Бюджет та ліміти ---
MAX_QUESTS_PER_DAY=5
LEGENDARY_BUDGET_RESERVE=440
